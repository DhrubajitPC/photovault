{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:prod": "NODE_ENV=prod nodemon --watch dist --ext js --exec node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate -j ts -f src/config/node-pg-migrate.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
